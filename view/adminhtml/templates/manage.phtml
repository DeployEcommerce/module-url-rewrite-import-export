<script>
require(['jquery', 'Magento_Ui/js/modal/confirm'], function ($, confirmation) {
    'use strict';
    var $form = $('#urlrewriteimportexport-import-form');
    $form.on('submit', function (e) {
        if (!$('#truncate_existing').is(':checked')) {
            return true;
        }
        e.preventDefault();
        confirmation({
            title: $.mage.__('Truncate the url_rewrite table?'),
            content: $.mage.__(
                'You ticked "truncate". This will permanently delete EVERY existing row in the '
                + 'url_rewrite table before importing. A safety backup will be written first, but '
                + 'this is irreversible without restoring a backup. Continue?'
            ),
            actions: {
                confirm: function () {
                    $form.off('submit').trigger('submit');
                }
            }
        });
        return false;
    });
});
</script>
